# PostgreSQL
POSTGRES_DB=contentor
POSTGRES_USER=contentor
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=changeme-use-a-real-secret-key
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=*
DJANGO_DEBUG=True

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# Platform
CONTENTOR_DOMAIN=localhost
CONTENTOR_SUPERUSERS=admin@contentor.com

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@contentor.com

# Storage (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=contentor-dev-private
AWS_ENDPOINT=https://fsn1.your-objectstorage.com
AWS_PRESIGNED_EXPIRY=3600

# Frontend
NEXT_PUBLIC_API_URL=http://django:8000
NEXT_PUBLIC_BASE_DOMAIN=localhost

# Live video / chat (Stream.io). NEXT_PUBLIC_GETSTREAM_API_KEY is the same key,
# baked into the customer frontend bundle for the in-browser client.
GETSTREAM_API_KEY=
GETSTREAM_API_SECRET=
NEXT_PUBLIC_GETSTREAM_API_KEY=

# MailCraft integration (sibling app). EMAILCRAFT_BASE_URL defaults to the hosted
# instance (mailcraft.contentor.app) if unset.
EMAILCRAFT_TOKEN=
# EMAILCRAFT_BASE_URL=https://mailcraft.contentor.app

# Google OAuth (Zoom OAuth is configured per-tenant in the DB, not here).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback/

# Billing (Stripe). Production refuses BILLING_BYPASS_ENABLED=true.
#
# To exercise the real Stripe flow locally you must:
#   1. Get a Stripe test-mode `sk_test_*` secret key + `pk_test_*` publishable.
#   2. Create monthly recurring Price IDs in Stripe for Starter and Pro in BOTH
#      USD and TRY (test mode), then drop the `price_*` IDs into the env vars
#      below. `seed_plans` will call `stripe.Price.retrieve` to validate them
#      when STRIPE_SECRET_KEY is set.
#   3. Run `stripe listen --forward-to http://localhost/api/webhooks/stripe/`
#      (or `make stripe-listen`) and copy the `whsec_*` secret it prints into
#      STRIPE_WEBHOOK_SECRET below.
#
# PRE-FLIGHT (TR coaches only): Confirm TRY presentment is enabled on your
# European Stripe account BEFORE running TR-currency tests. Stripe will reject
# checkout creation with `parameter_invalid_string_blank` or similar if TRY is
# not enabled for your merchant category. Verify in the Stripe Dashboard under
# Settings -> Payment methods -> Currencies.
BILLING_BYPASS_ENABLED=true
PAST_DUE_GRACE_DAYS=7
BILLING_FREE_PLAN_NAME=Free
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_USD=
STRIPE_PRICE_PRO_USD=
STRIPE_PRICE_STARTER_TRY=
STRIPE_PRICE_PRO_TRY=

# Web Push (VAPID) — generate with: vapid --gen ; vapid --applicationServerKey
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@contentor.app
