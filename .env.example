# PostgreSQL
POSTGRES_DB=contentor
POSTGRES_USER=contentor
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=changeme-use-a-real-secret-key
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=*
DJANGO_DEBUG=True

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# Platform
CONTENTOR_DOMAIN=contentor.localhost
CONTENTOR_SUPERUSERS=admin@contentor.com

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@contentor.com

# Storage (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=contentor-dev-private
AWS_ENDPOINT=https://fsn1.your-objectstorage.com
AWS_PRESIGNED_EXPIRY=3600

# Frontend
NEXT_PUBLIC_API_URL=http://django:8000
NEXT_PUBLIC_BASE_DOMAIN=contentor.localhost
