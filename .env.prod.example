# Contentor — home-server production env. Copy to .env.prod and fill the blanks.
# .env.prod is gitignored (secrets) but IS rsynced to the server by deploy.sh.
# DJANGO_SETTINGS_MODULE is forced to config.settings.prod by docker-compose.prod.yml.

# --- Platform ---------------------------------------------------------------
CONTENTOR_DOMAIN=contentor.app
# Comma-separated superuser emails seeded on first boot (seed_plans).
CONTENTOR_SUPERUSERS=taha.komur@trustedshops.com
# `.contentor.app` matches the apex + every tenant subdomain; localhost is for
# the in-container health probe; `django` is the internal service name the two
# Next.js apps fetch for SSR (Host: django) — omit it and those calls 400.
DJANGO_ALLOWED_HOSTS=.contentor.app,localhost,127.0.0.1,django
# Optional explicit CORS allow-list (the *.contentor.app regex is always on).
DJANGO_CORS_ALLOWED_ORIGINS=

# --- Django -----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=
# Production REFUSES to boot if this is true.
BILLING_BYPASS_ENABLED=false

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=contentor
POSTGRES_USER=contentor
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis / Celery ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- Frontends (NEXT_PUBLIC_* are baked at build) ---------------------------
NEXT_PUBLIC_API_URL=http://django:8000

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@contentor.app

# --- Coach mailbox (inbound) ------------------------------------------------
# REQUIRED for coaches to RECEIVE email. MAILBOX_INBOUND_SECRET must equal the
# secret set on the Cloudflare Email Worker (see infra/cloudflare/mailbox-worker,
# `wrangler secret put MAILBOX_INBOUND_SECRET`; generate with `openssl rand -hex 32`).
# CLOUDFLARE_EMAIL_WORKER_NAME is the deployed Worker's name (e.g. mailbox-inbound);
# if unset, enabling a coach mailbox will NOT bind inbound routing and no mail is received.
MAILBOX_INBOUND_SECRET=
CLOUDFLARE_EMAIL_WORKER_NAME=
# Domain for paid coaches' chosen `<x>@<domain>` addresses (platform mailbox
# tier). Needs a CF Email Routing catch-all on this zone bound to the same
# Worker as MAILBOX_INBOUND_SECRET. Empty disables the tier.
PLATFORM_MAIL_DOMAIN=contentor.app
# Superadmin platform inbox (public-schema mailbox): mail to any unclaimed
# address on PLATFORM_MAIL_DOMAIN lands here instead of being dropped, and
# replies are sent from this fixed address. Requires the CF Email Routing
# catch-all on PLATFORM_MAIL_DOMAIN to point at the Worker above (see the
# ops note in apps/mailbox/views.py's inbound() handler).
PLATFORM_SUPPORT_FROM=support@contentor.app

# --- Object storage (S3-compatible, e.g. Hetzner) ---------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=contentor-prod-private
AWS_ENDPOINT=https://fsn1.your-objectstorage.com
AWS_PRESIGNED_EXPIRY=3600

# --- Log pipeline (apps.logbook) ---------------------------------------------
# Shared secret between the vector container and Django's ingest endpoint.
# Generate: openssl rand -hex 32
LOGS_INGEST_TOKEN=

# --- Live video / chat (Stream.io) ------------------------------------------
GETSTREAM_API_KEY=
GETSTREAM_API_SECRET=

# --- MailCraft integration (sibling app at mailcraft.contentor.app) ---------
EMAILCRAFT_BASE_URL=https://mailcraft.contentor.app
EMAILCRAFT_TOKEN=

# --- Google OAuth (Zoom OAuth is configured per-tenant in the DB, not here) --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://contentor.app/api/v1/auth/google/callback/

# --- Billing (Stripe) — required: prod runs live billing --------------------
PAST_DUE_GRACE_DAYS=7
BILLING_FREE_PLAN_NAME=Free
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Prices are auto-created in Stripe from the amounts in
# backend/apps/core/management/commands/seed_plans.py (PLAN_AMOUNTS) on each
# deploy — you do NOT create Prices in the dashboard. These are OPTIONAL manual
# overrides: set a real `price_...` id to pin a specific Price; any other value
# (or blank) is ignored and the Price is provisioned automatically.
STRIPE_PRICE_STARTER_USD=
STRIPE_PRICE_PRO_USD=
STRIPE_PRICE_STARTER_TRY=
STRIPE_PRICE_PRO_TRY=

# Web Push (VAPID) — generate with: vapid --gen ; vapid --applicationServerKey
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@contentor.app

# --- AI features (Logo Brand Pack + Ask Contentor help bot + AI blog) ---
# AI_PROVIDER: "anthropic" (default; bills ANTHROPIC_API_KEY below) | "cli"
# (LOCAL DEV ONLY — prod refuses it at settings-import time).
# AI_PROVIDER=anthropic
# AI_CLI_BIN=claude
# AI_CLI_MODEL=haiku
ANTHROPIC_API_KEY=
# Logo Studio image-model icon marks (Gemini; unset = feature off)
GEMINI_API_KEY=
HELP_BOT_MODEL=claude-sonnet-5
HELP_BOT_TENANT_MONTHLY_USD=1
HELP_BOT_GLOBAL_MONTHLY_USD=50

# --- Error monitoring (Sentry) -------------------------------------------
# Prod ships sentry-sdk; error monitoring is OFF until you set a DSN here.
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.0
BLOG_AI_MONTHLY_BUDGET_USD=30
