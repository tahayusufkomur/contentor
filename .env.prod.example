# Contentor — home-server production env. Copy to .env.prod and fill the blanks.
# .env.prod is gitignored (secrets) but IS rsynced to the server by deploy.sh.
# DJANGO_SETTINGS_MODULE is forced to config.settings.prod by docker-compose.prod.yml.

# --- Platform ---------------------------------------------------------------
CONTENTOR_DOMAIN=contentor.app
# Comma-separated superuser emails seeded on first boot (seed_plans).
CONTENTOR_SUPERUSERS=taha.komur@trustedshops.com
# `.contentor.app` matches the apex + every tenant subdomain; localhost is for
# the in-container health probe.
DJANGO_ALLOWED_HOSTS=.contentor.app,localhost,127.0.0.1
# Optional explicit CORS allow-list (the *.contentor.app regex is always on).
DJANGO_CORS_ALLOWED_ORIGINS=

# --- Django -----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=
# Production REFUSES to boot if this is true.
BILLING_BYPASS_ENABLED=false

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=contentor
POSTGRES_USER=contentor
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis / Celery ---------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- Frontends (NEXT_PUBLIC_* are baked at build) ---------------------------
NEXT_PUBLIC_API_URL=http://django:8000

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@contentor.app

# --- Object storage (S3-compatible, e.g. Hetzner) ---------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=contentor-prod-private
AWS_ENDPOINT=https://fsn1.your-objectstorage.com
AWS_PRESIGNED_EXPIRY=3600

# --- Live video / chat (Stream.io) ------------------------------------------
GETSTREAM_API_KEY=
GETSTREAM_API_SECRET=

# --- MailCraft integration (sibling app at mailcraft.contentor.app) ---------
EMAILCRAFT_BASE_URL=https://mailcraft.contentor.app
EMAILCRAFT_TOKEN=

# --- Google OAuth (Zoom OAuth is configured per-tenant in the DB, not here) --
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://contentor.app/api/v1/auth/google/callback/

# --- Billing (Stripe) — required: prod runs live billing --------------------
PAST_DUE_GRACE_DAYS=7
BILLING_FREE_PLAN_NAME=Free
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Prices are auto-created in Stripe from the amounts in
# backend/apps/core/management/commands/seed_plans.py (PLAN_AMOUNTS) on each
# deploy — you do NOT create Prices in the dashboard. These are OPTIONAL manual
# overrides: set a real `price_...` id to pin a specific Price; any other value
# (or blank) is ignored and the Price is provisioned automatically.
STRIPE_PRICE_STARTER_USD=
STRIPE_PRICE_PRO_USD=
STRIPE_PRICE_STARTER_TRY=
STRIPE_PRICE_PRO_TRY=
